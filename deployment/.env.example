# Env for startup in docker container
API_DEBUG=False
API_HOST=0.0.0.0
API_PORT=8000

JWT_SECRET_KEY=super-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

DB_URL=postgresql+asyncpg://user:password@localhost:5432/openshelf
DB_DEBUG=False
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600